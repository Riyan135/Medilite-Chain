generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum RecordType {
  REPORT
  BILL
  PRESCRIPTION
  LAB_TEST
  INSURANCE
}

model User {
  id             String          @id @default(uuid())
  clerkId        String?         @unique
  password       String
  name           String
  email          String          @unique
  role           Role            @default(PATIENT)
  phone          String?
  isVerified     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  patientProfile PatientProfile?
  doctorNotes    DoctorNote[]    @relation("DoctorNotes")
  treatedRecords MedicalRecord[] @relation("DoctorRecords")
  consultingFor  PatientProfile[] @relation("ConsultingDoctor")

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  doctorAppointments Appointment[] @relation("DoctorAppointments")

  // Family Relations
  parentId         String?
  parent           User?     @relation("FamilyLink", fields: [parentId], references: [id])
  familyMembers    User[]    @relation("FamilyLink")
  
  relationToParent String?
  age              Int?
  gender           String?
}

model PatientProfile {
  id               String   @id @default(uuid())

  user             User     @relation(fields: [userId], references: [id])
  userId           String   @unique

  bloodGroup       String?
  allergies        String?
  medicalHistory   String?
  emergencyContact String?
  qrCode           String?  @unique

  // Relations
  records          MedicalRecord[]
  reminders        MedicineReminder[]
  notes            DoctorNote[]
  inventory        MedicineInventory[]
  symptomChecks    SymptomCheck[]
  appointments     Appointment[]

  consultingDoctor   User?  @relation("ConsultingDoctor", fields: [consultingDoctorId], references: [id])
  consultingDoctorId String?
}

model MedicalRecord {
  id          String         @id @default(uuid())

  // Patient relation
  patient     PatientProfile @relation(fields: [patientId], references: [id])
  patientId   String

  // Doctor relation (optional)
  doctor      User?          @relation("DoctorRecords", fields: [doctorId], references: [id])
  doctorId    String?

  type        RecordType
  title       String
  description String?
  fileUrl     String
  summary     Json?

  date        DateTime       @default(now())
  createdAt   DateTime       @default(now())
}

model MedicineReminder {
  id           String         @id @default(uuid())

  patient      PatientProfile @relation(fields: [patientId], references: [id])
  patientId    String

  medicineName String
  dosage       String
  frequency    String
  time         String
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean        @default(true)

  createdAt    DateTime       @default(now())
}

model MedicineInventory {
  id           String         @id @default(uuid())

  patient      PatientProfile @relation(fields: [patientId], references: [id])
  patientId    String

  name         String
  stock        Int
  minThreshold Int
  unit         String         @default("tablets")

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model DoctorNote {
  id        String         @id @default(uuid())

  doctor    User           @relation("DoctorNotes", fields: [doctorId], references: [id])
  doctorId  String

  patient   PatientProfile @relation(fields: [patientId], references: [id])
  patientId String

  title     String?
  note      String

  date      DateTime       @default(now())
  createdAt DateTime       @default(now())
}

model SymptomCheck {
  id               String         @id @default(uuid())

  patient          PatientProfile @relation(fields: [patientId], references: [id])
  patientId        String

  symptoms         String
  predictedDisease String
  doctorSuggested  String?
  careType         String?
  precautions      String?
  riskLevel        String?
  advice           String?

  date             DateTime       @default(now())
  createdAt        DateTime       @default(now())
}

model Message {
  id         String   @id @default(uuid())

  content    String

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String

  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId String

  createdAt  DateTime @default(now())
}

model Appointment {
  id        String         @id @default(uuid())
  
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  patientId String
  
  doctor    User           @relation("DoctorAppointments", fields: [doctorId], references: [id])
  doctorId  String
  
  date      String
  time      String
  reason    String?
  status    String         @default("PENDING") // PENDING, ACCEPTED, REJECTED, COMPLETED
  
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}